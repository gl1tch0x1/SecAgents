{
  "typeCheckingMode": "basic",
  "pythonVersion": "3.13",
  "pythonPlatform": "All",
  "include": ["src"],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.git",
    "**/.tox",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.*",
    "**/*.egg-info",
    "**/venv",
    "**/.venv",
    "**/build",
    "**/dist",
    "**/htmlcov",
    "**/.coverage"
  ],
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "reportPrivateUsage": false,
  "reportUnnecessaryIsInstance": false,
  "reportConstantRedefinition": false,
  "stubPath": "typings"
}
