# SecAgents Configuration File
# Copy this to .env and update with your actual values
# Or set these as environment variables with SECAGENTS_ prefix

# ============================================================================
# LLM PROVIDER SELECTION
# ============================================================================

# Primary LLM Provider (default: ollama)
# Options: openai, anthropic, ollama, qwen, deepseek, groq, xai
SECAGENTS_PROVIDER=ollama

# Default model name for the selected provider
SECAGENTS_MODEL=llama3.2

# ============================================================================
# API KEYS - Provider Credentials
# ============================================================================

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-api-key-here

# Anthropic Claude (https://console.anthropic.com/keys)
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Groq (https://console.groq.com/keys)
# SECAGENTS_GROQ_API_KEY=gsk-your-api-key-here

# DeepSeek (https://platform.deepseek.com/api_keys)
# SECAGENTS_DEEPSEEK_API_KEY=sk-your-api-key-here

# Qwen/Alibaba (https://dashscope.console.aliyun.com)
# SECAGENTS_QWEN_API_KEY=sk-your-api-key-here

# XAI / Grok (https://api.x.ai)
# SECAGENTS_XAI_API_KEY=your-api-key-here

# ============================================================================
# OLLAMA CONFIGURATION (Local AI)
# ============================================================================

# Ollama base URL (default: http://127.0.0.1:11434)
SECAGENTS_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Ollama Docker container name
SECAGENTS_OLLAMA_CONTAINER_NAME=secagents-ollama

# Ollama Docker image to pull
SECAGENTS_OLLAMA_DOCKER_IMAGE=ollama/ollama:latest

# Ollama host port mapping (default: 11434)
SECAGENTS_OLLAMA_HOST_PORT=11434

# ============================================================================
# OPTIONAL API ENDPOINTS (if using custom/self-hosted)
# ============================================================================

# DeepSeek custom endpoint
# SECAGENTS_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen custom endpoint
# SECAGENTS_QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ============================================================================
# MODEL PARAMETERS
# ============================================================================

# Temperature (0.0-2.0, lower = more deterministic)
SECAGENTS_TEMPERATURE=0.15

# Top-P sampling (0.0-1.0)
SECAGENTS_TOP_P=0.9

# Maximum tokens per response (256-128000)
SECAGENTS_MAX_TOKENS=4096

# ============================================================================
# AGENT BEHAVIOR
# ============================================================================

# Maximum turns per agent (1-200, default: 24)
SECAGENTS_MAX_AGENT_TURNS=24

# Use multi-agent team (Recon → Exploit → Validator → Remediator)
SECAGENTS_USE_AGENT_TEAM=true

# Recon agent turn budget (0-80)
SECAGENTS_RECON_TURNS=3

# Validator agent turn budget (0-80)
SECAGENTS_VALIDATION_TURNS=5

# Enable remediation pass (auto-fix recommendations)
SECAGENTS_RUN_REMEDIATION_PASS=true

# Parallel specialists (1-10)
# 1=off, 2=code+OSINT, 3=+Intel, 4=+IDOR/OAuth, 5=+Race, 6=+LLM
SECAGENTS_PARALLEL_SPECIALISTS=2

# ============================================================================
# MULTI-AI CONSENSUS (CONFIDENCE VOTING)
# ============================================================================

# Enable consensus voting across multiple AI models
SECAGENTS_USE_MULTI_AI_CONSENSUS=true

# Minimum agreement needed (1-10, default: 2)
SECAGENTS_CONSENSUS_MIN_AGREEMENT=2

# Models for consensus (comma-separated)
# SECAGENTS_CONSENSUS_MODELS=gpt-4-turbo,claude-3-opus,llama3.2

# Confidence threshold (0.0-1.0, default: 0.75)
SECAGENTS_CONFIDENCE_THRESHOLD=0.75

# Enable false positive filtering
SECAGENTS_ENABLE_FALSE_POSITIVE_FILTER=true

# ============================================================================
# SPECIALIST AGENTS - ENABLE/DISABLE
# ============================================================================

# Disable IDOR specialist
# SECAGENTS_DISABLE_IDOR=false

# Disable OAuth specialist
# SECAGENTS_DISABLE_OAUTH=false

# Disable Race condition specialist
# SECAGENTS_DISABLE_RACE=false

# Disable Intel specialist (threat feeds)
# SECAGENTS_DISABLE_INTEL=false

# Disable LLM prompt injection agent
# SECAGENTS_DISABLE_LLM_AGENT=false

# Force LLM agent even without AI detection
# SECAGENTS_FORCE_LLM_AGENT=false

# Skip Intel gathering (for air-gapped networks)
# SECAGENTS_SKIP_INTEL=false

# Race condition concurrency level (1-100)
SECAGENTS_RACE_CONCURRENCY=10

# ============================================================================
# DOCKER SANDBOX
# ============================================================================

# Docker sandbox image name
SECAGENTS_DOCKER_IMAGE_SANDBOX=secagents-sandbox:latest

# Docker sandbox shared memory size (for Chromium/heavy tools)
SECAGENTS_SANDBOX_SHM_SIZE=1g

# Docker command timeout in seconds (30-3600)
SECAGENTS_SANDBOX_COMMAND_TIMEOUT_SEC=300

# ============================================================================
# FILE LIMITS (For Context Window Management)
# ============================================================================

# Maximum bytes per file (bytes)
SECAGENTS_MAX_FILE_BYTES=120000

# Maximum files in analysis context
SECAGENTS_MAX_FILES_IN_CONTEXT=80

# ============================================================================
# NOTES
# ============================================================================
# 1. Uncomment and fill in the values you need
# 2. For API keys, use environment variables or .env file (both work)
# 3. Docker sandbox requires Docker daemon running
# 4. Ollama requires Docker for "local" AI model execution
# 5. For production, use environment variables, not .env files
# 6. Never commit API keys to version control!
